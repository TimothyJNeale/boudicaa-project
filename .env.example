# Boudicaa environment configuration
# Copy to .env and update values. Do NOT commit .env to git.

# =============================================================================
# CORE DJANGO SETTINGS
# =============================================================================

# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-change-me-in-production

# Debug mode — MUST be False in production
DEBUG=True

# Comma-separated hostnames (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# DATABASE
# =============================================================================
# Options: sqlite3 (default), mysql, postgresql

# SQLite (development default — no other DB_ vars needed)
DB_ENGINE=sqlite3

# MySQL (PythonAnywhere production)
# DB_ENGINE=mysql
# DB_NAME=yourusername$boudicaa
# DB_USER=yourusername
# DB_PASSWORD=your-mysql-password
# DB_HOST=yourusername.mysql.pythonanywhere-services.com
# DB_PORT=3306

# PostgreSQL (when PythonAnywhere upgrades to PostgreSQL 14+)
# DB_ENGINE=postgresql
# DB_NAME=yourusername$default
# DB_USER=yourusername
# DB_PASSWORD=your-postgres-password
# DB_HOST=yourusername.postgres.pythonanywhere-services.com
# DB_PORT=5432

# =============================================================================
# BOUDICAA SETTINGS
# =============================================================================

# Disable user registration (recommended for single-user deployment)
PROTECTED_MODE=False

# Items per page in list views
PAGINATE_BY=25

# =============================================================================
# EMAIL (required for password reset in production)
# =============================================================================
# Development default: console backend (prints to terminal)
# Production: set to django.core.mail.backends.smtp.EmailBackend

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=Boudicaa <your-email@gmail.com>
# SERVER_EMAIL=your-email@gmail.com
# PASSWORD_RESET_TIMEOUT=259200
